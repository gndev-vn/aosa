<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AOSA - @ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: #f5f5f7;
            color: #1d1d1f;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .container { max-width: 900px; margin: 0 auto; padding: 0 20px; width: 100%; }
        header {
            background: #fff;
            border-bottom: 1px solid #e5e5ea;
            padding: 16px 0;
            position: sticky; top: 0; z-index: 10;
        }
        header .container {
            display: flex; align-items: center; justify-content: space-between;
        }
        header h1 {
            font-size: 22px; font-weight: 700;
            background: linear-gradient(135deg, #007aff, #5856d6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        header nav a {
            color: #007aff; text-decoration: none; font-size: 14px; font-weight: 500;
            margin-left: 20px;
        }
        header nav a:hover { text-decoration: underline; }
        main { flex: 1; padding: 40px 0; }
        .card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            padding: 28px;
            margin-bottom: 20px;
        }
        .card h2 { font-size: 20px; font-weight: 600; margin-bottom: 16px; }
        .form-group { margin-bottom: 16px; }
        .form-group label {
            display: block; font-size: 14px; font-weight: 500;
            margin-bottom: 6px; color: #6e6e73;
        }
        .form-group input {
            width: 100%; padding: 10px 14px; font-size: 15px;
            border: 1.5px solid #e5e5ea; border-radius: 10px;
            outline: none; transition: border 0.2s;
        }
        .form-group input:focus { border-color: #007aff; }
        .btn {
            display: inline-block; padding: 10px 24px; font-size: 15px; font-weight: 600;
            border: none; border-radius: 10px; cursor: pointer;
            transition: opacity 0.2s;
            text-decoration: none;
        }
        .btn-primary { background: #007aff; color: #fff; }
        .btn-primary:hover { opacity: 0.85; }
        .btn-danger { background: #ff3b30; color: #fff; }
        .btn-danger:hover { opacity: 0.85; }
        .btn-outline {
            background: transparent; color: #007aff;
            border: 1.5px solid #007aff;
        }
        .btn-outline:hover { background: #007aff10; }
        .btn-sm { padding: 6px 14px; font-size: 13px; }
        .alert {
            padding: 12px 16px; border-radius: 10px; font-size: 14px;
            margin-bottom: 16px;
        }
        .alert-error { background: #ffe5e5; color: #c41e1e; }
        .alert-success { background: #e5f9e5; color: #1a7d1a; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 12px 8px; border-bottom: 1px solid #e5e5ea; font-size: 14px; }
        th { font-weight: 600; color: #6e6e73; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; }
        .badge {
            display: inline-block; padding: 2px 10px; border-radius: 20px;
            font-size: 12px; font-weight: 500;
        }
        .badge-default { background: #007aff20; color: #007aff; }
        .badge-member { background: #5856d620; color: #5856d6; }
        .flex { display: flex; align-items: center; gap: 8px; }
        .flex-between { display: flex; align-items: center; justify-content: space-between; }
        footer { text-align: center; padding: 20px; font-size: 13px; color: #8e8e93; }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <h1>AOSA</h1>
            <nav>
                @if (ViewData["IsAuthenticated"] is true)
                {
                    <a href="/repos">Repos</a>
                    <a href="/auth/logout">Logout</a>
                }
                else
                {
                    <a href="/auth/signin">Sign In</a>
                    <a href="/auth/signup">Sign Up</a>
                }
            </nav>
        </div>
    </header>
    <main>
        <div class="container">
            @RenderBody()
        </div>
    </main>
    <footer>
        <div class="container">AOSA &mdash; Self-hosted TOTP Manager</div>
    </footer>
</body>
</html>
